# ── Supabase PostgreSQL ───────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── App ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
JWT_SECRET=replace_with_64_random_chars_min
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://your-app.vercel.app

# ── Email (SMTP) ──────────────────────────────────────────────
# Office 365:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your_app_password
SMTP_FROM=alerts@yourcompany.com
SMTP_FROM_NAME=InspectTrack Alerts

# Gmail alternative:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password

# ── Scheduler ─────────────────────────────────────────────────
# Run alert check every day at 7:00 AM UTC (adjust for your timezone)
ALERT_CRON=0 7 * * *
APP_URL=https://your-app.vercel.app
