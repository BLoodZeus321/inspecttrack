# ============================================================
# InspectTrack — Environment Variables
# Copy this file to .env for local development.
# For Railway: paste each variable into Railway → Variables tab.
# ============================================================

# ── Supabase PostgreSQL ───────────────────────────────────────
#
# HOW TO GET THIS:
#   1. Go to Supabase dashboard → your project
#   2. Click Settings (gear icon) → Database
#   3. Scroll to "Connection string" section
#   4. Choose the "URI" tab
#   5. Copy the string — it looks like one of these:
#
# FORMAT A (direct connection — use this if available):
#   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# FORMAT B (connection pooler — use if Format A doesn't work):
#   postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# IMPORTANT: Replace [YOUR-PASSWORD] with your actual database password.
# Do NOT use your Supabase login password — use the database password
# you set when creating the project (or reset it under Settings → Database).
#
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Supabase Storage (for certificate file uploads) ──────────
# Get from: Supabase → Settings → API
# SUPABASE_URL: copy the Project URL
# SUPABASE_SERVICE_KEY: copy the service_role key (NOT the anon key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Generate a random 64-char string for this.
# Quick way: go to https://generate-secret.vercel.app/64
JWT_SECRET=replace_this_with_a_64_character_random_string_minimum_please

JWT_EXPIRES_IN=7d

# Your Vercel frontend URL (update after deploying frontend)
FRONTEND_URL=https://your-app.vercel.app

# ── Email / SMTP ──────────────────────────────────────────────
#
# OPTION A — Office 365 (recommended for company email)
# If you have MFA enabled, generate an App Password:
#   https://myaccount.microsoft.com → Security → App passwords
#
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your_app_password_here
SMTP_FROM=alerts@yourcompany.com
SMTP_FROM_NAME=InspectTrack Alerts

# OPTION B — Gmail
# You MUST use an App Password (not your main Gmail password).
# Enable 2FA first, then: myaccount.google.com → Security → App passwords
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx

# OPTION C — Brevo (free 300 emails/day, no credit card)
# Sign up at brevo.com → SMTP & API → SMTP settings
#
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your_brevo_login_email
# SMTP_PASS=your_brevo_smtp_key

# ── Alert Scheduler ───────────────────────────────────────────
# Cron expression — when to run the daily alert check.
# "0 4 * * *" = 4:00 AM UTC = 7:00 AM Qatar time (UTC+3)
# "0 7 * * *" = 7:00 AM UTC = 10:00 AM Qatar time
ALERT_CRON=0 4 * * *

# Your app's public URL — used in alert email "View Equipment" buttons
APP_URL=https://your-app.vercel.app
